@model EcoSphere.Core.Models.EnergyConsumption
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Tüketim Ekle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Enerji Tüketim Kaydı</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Harcanan kaynak miktarını girin, CO2 miktarı otomatik hesaplanacaktır</p>
    </div>
    <div class="page-actions">
        <a href="/EnergyConsumption" class="btn btn-outline">🎛️ Listeye Dön</a>
    </div>
</div>

<div class="content-card form-card">
    <form method="post" action="/EnergyConsumption/Create">
        <div class="form-group">
            <label class="form-label-styled">Enerji / Tüketim Tipi</label>
            <select id="typeSelect" name="ConsumptionType" class="form-select-styled" onchange="updateUnit()">
                <option value="Elektrik">Elektrik (Aydınlatma, Makineler vb.)</option>
                <option value="Doğalgaz">Doğalgaz (Isınma vb.)</option>
                <option value="Yakıt">Yakıt (Şirket Araçları, Jeneratör vb.)</option>
            </select>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label-styled">Tüketim Miktarı</label>
                <input type="number" step="any" name="Quantity" class="form-input-styled" placeholder="Miktar girin" required />
            </div>
            <div class="form-group">
                <label class="form-label-styled">Ölçü Birimi</label>
                <input type="text" id="unitInput" name="Unit" class="form-input-styled" value="kWh" readonly style="background: #f1f5f9; cursor: not-allowed;" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 10px;">
            Tüketim Kaydını Kaydet
        </button>
    </form>
</div>

<script>
    function updateUnit() {
        var select = document.getElementById("typeSelect");
        var unitInput = document.getElementById("unitInput");
        if (select.value === "Elektrik") {
            unitInput.value = "kWh";
        } else if (select.value === "Doğalgaz") {
            unitInput.value = "m3";
        } else if (select.value === "Yakıt") {
            unitInput.value = "Litre";
        }
    }
</script>
