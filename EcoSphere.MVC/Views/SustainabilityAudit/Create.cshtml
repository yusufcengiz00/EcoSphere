@model EcoSphere.Core.Models.SustainabilityAudit
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Denetim Ekle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Denetim Ekle</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Departman denetim puanını ve tespitlerini girin</p>
    </div>
    <div class="page-actions">
        <a href="/SustainabilityAudit" class="btn btn-outline">🎛️ Listeye Dön</a>
    </div>
</div>

<div class="content-card form-card">
    <form method="post" action="/SustainabilityAudit/Create">
        <div class="form-group">
            <label class="form-label-styled">Denetlenen Departman</label>
            <select name="DepartmentName" class="form-select-styled">
                <option value="Üretim Departmanı">Üretim Departmanı</option>
                <option value="Lojistik Departmanı">Lojistik Departmanı</option>
                <option value="Pazarlama Departmanı">Pazarlama Departmanı</option>
                <option value="İnsan Kaynakları">İnsan Kaynakları</option>
                <option value="Bilgi Teknolojileri">Bilgi Teknolojileri</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label-styled">Denetçi Adı Soyadı</label>
            <input type="text" name="AuditorName" class="form-input-styled" placeholder="örn. Zeynep Kaya" required autocomplete="off" />
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label-styled">Denetim Tarihi</label>
                <input type="date" name="AuditDate" class="form-input-styled" required />
            </div>
            <div class="form-group">
                <label class="form-label-styled">Denetim Skoru (1 - 100)</label>
                <input type="number" min="1" max="100" name="Score" class="form-input-styled" placeholder="85" required />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label-styled">Denetim Bulguları</label>
            <textarea name="Findings" class="form-input-styled" rows="4" placeholder="Denetimde öne çıkan olumlu/olumsuz bulguları buraya yazın..." required></textarea>
        </div>

        <div class="form-group">
            <label class="form-label-styled">Önerilen Aksiyonlar</label>
            <textarea name="Recommendations" class="form-input-styled" rows="4" placeholder="Sürdürülebilirliği artırmak için tavsiye edilen aksiyonlar..." required></textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 10px;">
            Denetim Raporunu Kaydet
        </button>
    </form>
</div>
