@model IEnumerable<EcoSphere.Core.Models.SustainabilityGoal>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sürdürülebilirlik Hedefleri";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Sürdürülebilirlik Hedefleri (Admin)</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Şirket genelinde belirlenen aktif çevre hedefleri</p>
    </div>
    <div class="page-actions">
        <a href="/SustainabilityGoal/Create" class="btn btn-primary">
            <span>➕</span> Yeni Hedef Ekle
        </a>
    </div>
</div>

<div class="content-card">
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Hedef Başlığı</th>
                    <th>Hedef Metrik</th>
                    <th>Hedef Değer</th>
                    <th>Mevcut Değer</th>
                    <th>Birim</th>
                    <th>Hedef Tarih</th>
                    <th>Durum</th>
                    <th style="text-align: right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Title</strong></td>
                        <td>@item.TargetMetric</td>
                        <td>@item.TargetValue</td>
                        <td>@item.CurrentValue</td>
                        <td>@item.Unit</td>
                        <td>@item.TargetDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <span class="badge @(item.Status == "Tamamlandı" ? "badge-success" : item.Status == "Başarısız" ? "badge-danger" : "badge-warning")">
                                @item.Status
                            </span>
                        </td>
                        <td style="text-align: right;">
                            <div style="display: inline-flex; gap: 8px; justify-content: flex-end;">
                                <a href="/SustainabilityGoal/Edit/@item.Id" class="btn btn-outline btn-sm">🖊️ Düzenle</a>
                                <form method="post" action="/SustainabilityGoal/Delete/@item.Id" onsubmit="return confirm('Bu hedefi silmek istediğinize emin misiniz?');" style="margin:0;">
                                    <button type="submit" class="btn btn-danger btn-sm">🗑️ Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
