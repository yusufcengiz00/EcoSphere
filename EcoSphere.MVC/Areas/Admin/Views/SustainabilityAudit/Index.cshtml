@model IEnumerable<EcoSphere.Core.Models.SustainabilityAudit>
@{
    ViewData["Title"] = "Çevre Denetimleri";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Çevre Denetimleri</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Departmanlara yapılan sürdürülebilirlik denetim kayıtları</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/SustainabilityAudit/Create" class="btn btn-primary">
            <span>➕</span> Yeni Denetim Ekle
        </a>
    </div>
</div>

<div class="content-card">
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Denetlenen Departman</th>
                    <th>Denetçi</th>
                    <th>Denetim Tarihi</th>
                    <th>Puan</th>
                    <th>Önemli Bulgular</th>
                    <th>Öneriler</th>
                    <th style="text-align: right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.DepartmentName</strong></td>
                        <td>@item.AuditorName</td>
                        <td>@item.AuditDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <span class="badge @(item.Score >= 80 ? "badge-success" : item.Score >= 60 ? "badge-warning" : "badge-danger")">
                                @item.Score / 100
                            </span>
                        </td>
                        <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Findings">@item.Findings</td>
                        <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Recommendations">@item.Recommendations</td>
                        <td style="text-align: right;">
                            <div style="display: inline-flex; gap: 8px; justify-content: flex-end;">
                                <a href="/Admin/SustainabilityAudit/Edit/@item.Id" class="btn btn-outline btn-sm">🖊️ Düzenle</a>
                                <form method="post" action="/Admin/SustainabilityAudit/Delete/@item.Id" onsubmit="return confirm('Bu denetimi silmek istediğinize emin misiniz?');" style="margin:0;">
                                    <button type="submit" class="btn btn-danger btn-sm">🗑️ Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
