@model IEnumerable<EcoSphere.Core.Models.EcoCertificate>
@{
    ViewData["Title"] = "Çevre Sertifikaları";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Çevre Sertifikaları</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Kurumumuzun aldığı resmi ekolojik sertifikalar</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/EcoCertificate/Create" class="btn btn-primary">
            <span>➕</span> Yeni Sertifika Ekle
        </a>
    </div>
</div>

<div class="content-card">
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>Sertifika Adı</th>
                    <th>Veren Kuruluş</th>
                    <th>Veriliş Tarihi</th>
                    <th>Geçerlilik Tarihi</th>
                    <th>Durum</th>
                    <th style="text-align: right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.CertificateImagePath))
                            {
                                <img src="@item.CertificateImagePath" class="preview-img" onclick="openImageModal('@item.CertificateImagePath')" title="Büyütmek için tıklayın" />
                            }
                            else
                            {
                                <span style="color: var(--text-muted); font-size: 12px; font-style: italic;">Yüklenmedi</span>
                            }
                        </td>
                        <td><strong>@item.CertificateName</strong></td>
                        <td>@item.IssuingOrganization</td>
                        <td>@item.IssueDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.ExpiryDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <span class="badge @(item.Status == "Geçerli" ? "badge-success" : item.Status == "Yenileme Bekliyor" ? "badge-warning" : "badge-danger")">
                                @item.Status
                            </span>
                        </td>
                        <td style="text-align: right;">
                            <div style="display: inline-flex; gap: 8px; justify-content: flex-end;">
                                <a href="/Admin/EcoCertificate/Edit/@item.Id" class="btn btn-outline btn-sm">🖊️ Düzenle</a>
                                <form method="post" action="/Admin/EcoCertificate/Delete/@item.Id" onsubmit="return confirm('Bu sertifikayı silmek istediğinize emin misiniz?');" style="margin:0;">
                                    <button type="submit" class="btn btn-danger btn-sm">🗑️ Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
