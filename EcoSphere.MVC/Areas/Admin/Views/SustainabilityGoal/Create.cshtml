@model EcoSphere.Core.Models.SustainabilityGoal
@{
    ViewData["Title"] = "Yeni Hedef Ekle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Yeni Hedef Oluştur</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Yeni bir sürdürülebilirlik hedefi ekleyin</p>
    </div>
    <div class="page-actions">
        <a href="/Admin/SustainabilityGoal" class="btn btn-outline">🎛️ Listeye Dön</a>
    </div>
</div>

<div class="content-card form-card">
    <form method="post" action="/Admin/SustainabilityGoal/Create">
        <div class="form-group">
            <label class="form-label-styled">Hedef Başlığı</label>
            <input type="text" name="Title" class="form-input-styled" placeholder="örn. Yıllık Karbon Emisyonu Azaltımı" required autocomplete="off" />
        </div>

        <div class="form-group">
            <label class="form-label-styled">Hedef Metrik</label>
            <input type="text" name="TargetMetric" class="form-input-styled" placeholder="örn. CO2 Azaltımı" required autocomplete="off" />
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label-styled">Hedef Değer</label>
                <input type="number" step="any" name="TargetValue" class="form-input-styled" placeholder="10000" required />
            </div>
            <div class="form-group">
                <label class="form-label-styled">Mevcut Değer</label>
                <input type="number" step="any" name="CurrentValue" class="form-input-styled" placeholder="0" required />
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label class="form-label-styled">Birim</label>
                <input type="text" name="Unit" class="form-input-styled" placeholder="örn. kg CO2, % veya kWh" required autocomplete="off" />
            </div>
            <div class="form-group">
                <label class="form-label-styled">Hedef Tarih</label>
                <input type="date" name="TargetDate" class="form-input-styled" required />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label-styled">Durum</label>
            <select name="Status" class="form-select-styled">
                <option value="Aktif">Aktif</option>
                <option value="Tamamlandı">Tamamlandı</option>
                <option value="Başarısız">Başarısız</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 10px;">
            Hedefi Kaydet
        </button>
    </form>
</div>
