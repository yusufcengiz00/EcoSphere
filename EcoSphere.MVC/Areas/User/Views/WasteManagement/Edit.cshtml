@model EcoSphere.Core.Models.WasteManagement
@{
    ViewData["Title"] = "Kaydı Düzenle";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Atık Kaydını Düzenle</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Atık bilgilerini güncelleyin</p>
    </div>
    <div class="page-actions">
        <a href="/User/WasteManagement" class="btn btn-outline">🎛️ Listeye Dön</a>
    </div>
</div>

<div class="content-card form-card">
    <form method="post" action="/User/WasteManagement/Edit" enctype="multipart/form-data">
        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="form-group">
            <label class="form-label-styled">Atık Türü</label>
            <select name="WasteType" class="form-select-styled">
                <!option value="Plastik" @(Model.WasteType == "Plastik" ? "selected" : "")>Plastik</!option>
                <!option value="Kağıt" @(Model.WasteType == "Kağıt" ? "selected" : "")>Kağıt</!option>
                <!option value="Cam" @(Model.WasteType == "Cam" ? "selected" : "")>Cam</!option>
                <!option value="Organik" @(Model.WasteType == "Organik" ? "selected" : "")>Organik / Yemek</!option>
                <!option value="Elektronik" @(Model.WasteType == "Elektronik" ? "selected" : "")>Elektronik Atık (E-Waste)</!option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label-styled">Atık Ağırlığı (kg)</label>
            <input type="number" step="any" name="WeightKg" class="form-input-styled" value="@Model.WeightKg" required />
        </div>

        <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-top: 15px; margin-bottom: 20px;">
            <input type="checkbox" id="isRecycled" name="IsRecycled" value="true" style="width: 18px; height: 18px; cursor: pointer;" @(Model.IsRecycled ? "checked" : "") />
            <input type="hidden" name="IsRecycled" value="false" />
            <label for="isRecycled" style="font-size: 14px; font-weight: 500; cursor: pointer;">Geri dönüşüm tesisine teslim edildi</label>
        </div>

        <div class="form-group">
            <label class="form-label-styled">Mevcut Fiş Görseli</label>
            <div style="margin-bottom: 12px;">
                @if (!string.IsNullOrEmpty(Model.ReceiptImagePath))
                {
                    <img src="@Model.ReceiptImagePath" style="max-width: 150px; border-radius: 8px; border: 1px solid var(--border-color); cursor: pointer;" onclick="openImageModal('@Model.ReceiptImagePath')" title="Büyütmek için tıklayın" />
                }
                else
                {
                    <span style="color: var(--text-muted); font-size: 13px; font-style: italic;">Fiş görseli yüklenmemiş.</span>
                }
            </div>
            <label class="form-label-styled">Fiş Görselini Değiştir</label>
            <input type="file" name="receiptImage" class="form-input-styled" accept="image/*" />
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 10px;">
            Değişiklikleri Kaydet
        </button>
    </form>
</div>
