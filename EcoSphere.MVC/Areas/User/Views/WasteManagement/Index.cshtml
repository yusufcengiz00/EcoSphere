@model IEnumerable<EcoSphere.Core.Models.WasteManagement>
@{
    ViewData["Title"] = "Atık Yönetim Kayıtları";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Atık Yönetim Kayıtları</h1>
        <p style="color: var(--text-muted); font-size: 14px; margin-top: 4px;">Departmanımızın atık bertaraf ve geri dönüşüm kayıtları</p>
    </div>
    <div class="page-actions">
        <a href="/User/WasteManagement/Create" class="btn btn-primary">
            <span>➕</span> Yeni Atık Kaydı Ekle
        </a>
    </div>
</div>

<div class="content-card">
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Belge / Fiş</th>
                    <th>Atık Tipi</th>
                    <th>Ağırlık</th>
                    <th>Kayıt Tarihi</th>
                    <th>Geri Dönüştürüldü mü?</th>
                    <th style="text-align: right;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ReceiptImagePath))
                            {
                                <img src="@item.ReceiptImagePath" class="preview-img" onclick="openImageModal('@item.ReceiptImagePath')" title="Fişi büyütmek için tıklayın" />
                            }
                            else
                            {
                                <span style="color: var(--text-muted); font-size: 12px; font-style: italic;">Fiş Yok</span>
                            }
                        </td>
                        <td><strong>@item.WasteType</strong></td>
                        <td>@item.WeightKg kg</td>
                        <td>@item.DateLogged.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(item.IsRecycled ? "badge-success" : "badge-warning")">
                                @(item.IsRecycled ? "Evet" : "Hayır")
                            </span>
                        </td>
                        <td style="text-align: right;">
                            <div style="display: inline-flex; gap: 8px; justify-content: flex-end;">
                                <a href="/User/WasteManagement/Edit/@item.Id" class="btn btn-outline btn-sm">🖊️ Düzenle</a>
                                <form method="post" action="/User/WasteManagement/Delete/@item.Id" onsubmit="return confirm('Bu atık kaydını silmek istediğinize emin misiniz?');" style="margin:0;">
                                    <button type="submit" class="btn btn-danger btn-sm">🗑️ Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
